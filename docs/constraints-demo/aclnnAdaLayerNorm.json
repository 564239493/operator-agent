  "other_parameters": [
    {
      "name": "B",
      "type": "aclIntArray",
      "description": "表示x、scale、shift以及out的shape中的前缀维度序列。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "0 <= len(B) <= 6 and all(dim > 0 for dim in B) and x_shape == B + [S, H] and (scale_shape == B + [H] or scale_shape == B + [1, H]) and (shift_shape == B + [H] or shift_shape == B + [1, H]) and out_shape == B + [S, H]"
        }
      ]
    },
    {
      "name": "S",
      "type": "int64_t",
      "description": "表示输入张量x和输出张量out的序列维大小。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "S > 0 and x_shape == B + [S, H] and out_shape == B + [S, H]"
        }
      ]
    },
    {
      "name": "H",
      "type": "int64_t",
      "description": "表示输入张量x的最后一维大小，同时与scale、shift的最后一维及weightOptional、biasOptional的唯一维度一致。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "H > 0 and x_shape == B + [S, H] and (scale_shape == B + [H] or scale_shape == B + [1, H]) and (shift_shape == B + [H] or shift_shape == B + [1, H]) and (weightOptional_shape is None or weightOptional_shape == [H]) and (biasOptional_shape is None or biasOptional_shape == [H]) and out_shape == B + [S, H]"
        }
      ]
    }
  ],

  "operation_name": "aclnnAdaLayerNorm",
  "description": "接口功能：AdaLayerNorm算子将LayerNorm和下游的Add、Mul融合起来，通过自适应参数scale和shift来调整归一化过程。\n计算公式：\nout = LayerNorm(x) * (1 + scale) + shift\nLayerNorm计算公式：\nLayerNorm(x) = {{x-E(x)}\\over\\sqrt {Var(x)+epsilon}} * weightOptional + biasOptional\n其中，E(x)表示输入的均值，Var(x)表示输入的方差。",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "type_equality",
      "params": [
        "x",
        "scale",
        "shift",
        "weightOptional",
        "biasOptional",
        "out"
      ],
      "expr": "(scale.dtype == x.dtype) and (shift.dtype == x.dtype) and ((weightOptional is None) or (weightOptional.dtype == x.dtype)) and ((biasOptional is None) or (biasOptional.dtype == x.dtype)) and (out.dtype == x.dtype)",
      "description": "scale、shift、out的数据类型必须与x一致；weightOptional和biasOptional在提供时，其数据类型也必须与x一致。",
      "source": "x",
      "target": [
        "scale",
        "shift",
        "weightOptional",
        "biasOptional",
        "out"
      ]
    },
    {
      "type": "shape_choice",
      "params": [
        "x",
        "scale"
      ],
      "expr": "((len(scale.shape) == len(x.shape) - 1) and (scale.shape[:-1] == x.shape[:-2]) and (scale.shape[-1] == x.shape[-1])) or ((len(scale.shape) == len(x.shape)) and (scale.shape[:-2] == x.shape[:-2]) and (scale.shape[-2] == 1) and (scale.shape[-1] == x.shape[-1]))",
      "description": "scale的shape必须是[B, H]或[B, 1, H]，其中B部分的维度数量和各维大小与x的前缀维一致，H等于x的最后一维。",
      "source": "x",
      "target": [
        "scale"
      ]
    },
    {
      "type": "shape_choice",
      "params": [
        "x",
        "shift"
      ],
      "expr": "((len(shift.shape) == len(x.shape) - 1) and (shift.shape[:-1] == x.shape[:-2]) and (shift.shape[-1] == x.shape[-1])) or ((len(shift.shape) == len(x.shape)) and (shift.shape[:-2] == x.shape[:-2]) and (shift.shape[-2] == 1) and (shift.shape[-1] == x.shape[-1]))",
      "description": "shift的shape必须是[B, H]或[B, 1, H]，其中B部分的维度数量和各维大小与x的前缀维一致，H等于x的最后一维。",
      "source": "x",
      "target": [
        "shift"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "x",
        "weightOptional"
      ],
      "expr": "(weightOptional is None) or ((len(weightOptional.shape) == 1) and (weightOptional.shape[0] == x.shape[-1]))",
      "description": "weightOptional在提供时，shape必须为[H]，其中H等于x的最后一维。",
      "source": "x",
      "target": [
        "weightOptional"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "x",
        "biasOptional"
      ],
      "expr": "(biasOptional is None) or ((len(biasOptional.shape) == 1) and (biasOptional.shape[0] == x.shape[-1]))",
      "description": "biasOptional在提供时，shape必须为[H]，其中H等于x的最后一维。",
      "source": "x",
      "target": [
        "biasOptional"
      ]
    },
    {
      "type": "shape_equality",
      "params": [
        "x",
        "out"
      ],
      "expr": "out.shape == x.shape",
      "description": "out的shape必须与x完全一致。",
      "source": "x",
      "target": [
        "out"
      ]
    }
  ],

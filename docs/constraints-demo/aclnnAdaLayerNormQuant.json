        "biasOptional"
      ]
    },
    {
      "type": "type_dependency",
      "params": [
        "x",
        "smoothScalesOptional"
      ],
      "expr": "(smoothScalesOptional is None) or (smoothScalesOptional.dtype == x.dtype)",
      "description": "如果提供smoothScalesOptional，其数据类型必须与x一致。",
      "source": "x",
      "target": [
        "smoothScalesOptional"
      ]
    },
    {
      "type": "shape_choice",
      "params": [
        "x",
        "scale"
      ],
      "expr": "((len(scale.shape) == len(x.shape) - 1) and (scale.shape[:-1] == x.shape[:-2]) and (scale.shape[-1] == x.shape[-1])) or ((len(scale.shape) == len(x.shape)) and (scale.shape[:-2] == x.shape[:-2]) and (scale.shape[-2] == 1) and (scale.shape[-1] == x.shape[-1]))",
      "description": "参数scale的shape必须是[B, H]或[B, 1, H]，其中B部分与x的前缀维度一致，H与x最后一维一致。",
      "source": "x",
      "target": [
        "scale"
      ]
    },
    {
      "type": "shape_choice",
      "params": [
        "x",
        "shift"
      ],
      "expr": "((len(shift.shape) == len(x.shape) - 1) and (shift.shape[:-1] == x.shape[:-2]) and (shift.shape[-1] == x.shape[-1])) or ((len(shift.shape) == len(x.shape)) and (shift.shape[:-2] == x.shape[:-2]) and (shift.shape[-2] == 1) and (shift.shape[-1] == x.shape[-1]))",
      "description": "参数shift的shape必须是[B, H]或[B, 1, H]，其中B部分与x的前缀维度一致，H与x最后一维一致。",
      "source": "x",
      "target": [
        "shift"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "x",
        "weightOptional"
      ],
      "expr": "(weightOptional is None) or ((len(weightOptional.shape) == 1) and (weightOptional.shape[0] == x.shape[-1]))",
      "description": "如果提供weightOptional，其shape必须为[H]，且H与x最后一维一致。",
      "source": "x",
      "target": [
        "weightOptional"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "x",
        "biasOptional"
      ],
      "expr": "(biasOptional is None) or ((len(biasOptional.shape) == 1) and (biasOptional.shape[0] == x.shape[-1]))",
      "description": "如果提供biasOptional，其shape必须为[H]，且H与x最后一维一致。",
      "source": "x",
      "target": [
        "biasOptional"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "x",
        "smoothScalesOptional"
      ],
      "expr": "(smoothScalesOptional is None) or ((len(smoothScalesOptional.shape) == 1) and (smoothScalesOptional.shape[0] == x.shape[-1]))",
      "description": "如果提供smoothScalesOptional，其shape必须为[H]，且H与x最后一维一致。",
      "source": "x",
      "target": [
        "smoothScalesOptional"
      ]
    },
    {
      "type": "shape_equality",
      "params": [
        "x",
        "out"
      ],
      "expr": "out.shape == x.shape",
      "description": "输出out的shape必须与输入x完全一致。",
      "source": "x",
      "target": [
        "out"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "x",
        "quantScale"
      ],
      "expr": "(len(quantScale.shape) == len(x.shape) - 1) and (quantScale.shape[:-1] == x.shape[:-2]) and (quantScale.shape[-1] == x.shape[-2])",
      "description": "输出quantScale的shape必须为[B, S]，其中B部分与x的前缀维度一致，S与x的倒数第二维一致。",
      "source": "x",
      "target": [
        "quantScale"
      ]
    },
    {
      "type": "shape_equality",
      "params": [
        "quantScale",
        "quantOffsetOptional"
      ],
      "expr": "(quantOffsetOptional is None) or (quantOffsetOptional.shape == quantScale.shape)",
      "description": "如果提供quantOffsetOptional，其shape必须与quantScale完全一致。",
      "source": "quantScale",
      "target": [
        "quantOffsetOptional"
      ]
    }
  ],

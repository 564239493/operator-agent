  "operation_name": "aclnnAdaptiveAvgPool2d",
  "description": "在指定二维输出shape信息（outputSize）的情况下，完成张量self的2D自适应平均池化计算。aclnnAdaptiveAvgPool2d与aclnnAvgPool2d不同的是，aclnnAdaptiveAvgPool2d只需要指定输出的大小，就可以自动推导出kernel的大小与对应的步长。",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "type_equality",
      "params": [
        "self",
        "out"
      ],
      "expr": "self.dtype == out.dtype",
      "description": "self和out的数据类型必须一致。",
      "source": null,
      "target": null
    },
    {
      "type": "format_equality",
      "params": [
        "self",
        "out"
      ],
      "expr": "self.format == out.format",
      "description": "self和out的数据格式必须一致。",
      "source": null,
      "target": null
    },
    {
      "type": "shape_dependency",
      "params": [
        "self",
        "out"
      ],
      "expr": "len(out.shape) == len(self.shape) and out.shape[:-2] == self.shape[:-2]",
      "description": "out的维度数必须与self一致，且除最后两个空间维外，其余维度与self对应维度相同。",
      "source": "self",
      "target": [
        "out"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "outputSize",
        "out"
      ],
      "expr": "out.shape[-2:] == outputSize",
      "description": "out的最后两个维度Hout和Wout必须等于outputSize指定的值。",
      "source": "outputSize",
      "target": [
        "out"
      ]
    }
  ],
  "platform_specifics": [
    {
      "platform": "Atlas A3 训练系列产品/Atlas A3 推理系列产品",
      "description": "是否支持：√",
      "constraint_detail": ""
    },

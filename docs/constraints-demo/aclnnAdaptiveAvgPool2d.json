      "constraint_detail": ""
    },
    {
      "platform": "Atlas 训练系列产品、Atlas 推理系列产品",
      "description": "Atlas 训练系列产品、Atlas 推理系列产品：不支持BFLOAT16数据类型。",
      "constraint_detail": "self.dtype != 'BFLOAT16' and out.dtype != 'BFLOAT16'"
    }
  ],
  "other_parameters": [
    {
      "name": "N",
      "type": "int64_t",
      "description": "4维场景下 self 和 out 的批次维大小。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "len(self.shape) == 4 and len(out.shape) == 4 and self.shape[0] == N and out.shape[0] == N"
        }
      ]
    },
    {
      "name": "C",
      "type": "int64_t",
      "description": "self 和 out 的通道维大小。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "((len(self.shape) == 4 and len(out.shape) == 4 and self.shape[1] == C and out.shape[1] == C) or (len(self.shape) == 3 and len(out.shape) == 3 and self.shape[0] == C and out.shape[0] == C))"
        }
      ]
    },
    {
      "name": "Hin",
      "type": "int64_t",
      "description": "self 的输入高度。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "((len(self.shape) == 4 and len(out.shape) == 4 and self.shape[2] == Hin) or (len(self.shape) == 3 and len(out.shape) == 3 and self.shape[1] == Hin))"
        }
      ]
    },
    {
      "name": "Win",
      "type": "int64_t",
      "description": "self 的输入宽度。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "((len(self.shape) == 4 and len(out.shape) == 4 and self.shape[3] == Win) or (len(self.shape) == 3 and len(out.shape) == 3 and self.shape[2] == Win))"
        }
      ]
    },
    {
      "name": "Hout",
      "type": "int64_t",
      "description": "outputSize 和 out 对应的输出高度。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "((len(self.shape) == 4 and len(out.shape) == 4 and len(outputSize) == 2 and outputSize[0] == Hout and out.shape[2] == Hout) or (len(self.shape) == 3 and len(out.shape) == 3 and len(outputSize) == 2 and outputSize[0] == Hout and out.shape[1] == Hout))"
        }
      ]
    },
    {
      "name": "Wout",
      "type": "int64_t",
      "description": "outputSize 和 out 对应的输出宽度。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "((len(self.shape) == 4 and len(out.shape) == 4 and len(outputSize) == 2 and outputSize[1] == Wout and out.shape[3] == Wout) or (len(self.shape) == 3 and len(out.shape) == 3 and len(outputSize) == 2 and outputSize[1] == Wout and out.shape[2] == Wout))"
        }
      ]
    }
  ],
  "functions": [
    {
      "api_name": "aclnnAdaptiveAvgPool2dGetWorkspaceSize",
      "description": "第一段接口用于获取aclnnAdaptiveAvgPool2d计算所需的workspace大小以及包含算子计算流程的执行器，并完成入参校验。",
      "parameters": [
        {
          "name": "self",
          "role": "input",
          "type": "aclTensor",
          "is_optional": false,
          "description": "Device侧的aclTensor。",
          "format": [
            "NCHW",
            "NCL"
          ]
        },
        {
          "name": "outputSize",
          "role": "input",
          "type": "aclIntArray",
          "is_optional": false,
          "description": "输出Tensor在HW维度上的Size大小。",
          "format": null
        },
        {
          "name": "out",
          "role": "output",
          "type": "aclTensor",
          "is_optional": false,
          "description": "Device侧的aclTensor。",
          "format": [
            "NCHW",
            "NCL"
          ]
        },
        {
          "name": "workspaceSize",
          "role": "output",
          "type": "uint64_t",
          "is_optional": false,
          "description": "返回用户需要在Device侧申请的workspace大小。",
          "format": null
        },
        {
          "name": "executor",
          "role": "output",
          "type": "aclOpExecutor",
          "is_optional": false,
          "description": "返回op执行器，包含了算子计算流程。",
          "format": null
        }
      ]
    },
    {
      "api_name": "aclnnAdaptiveAvgPool2d",
      "description": "第二段接口用于执行自适应平均池化计算，依赖第一段接口返回的workspace信息和executor。",
      "parameters": [
        {
          "name": "workspace",
          "role": "input",
          "type": "void",
          "is_optional": false,
          "description": "在 Device 侧申请的 workspace 内存地址。",
          "format": null
        },
        {
          "name": "workspaceSize",
          "role": "input",
          "type": "uint64_t",
          "is_optional": false,
          "description": "在Device侧申请的workspace大小，由第一段接口aclnnAdaptiveAvgPool2dGetWorkspaceSize获取。",
          "format": null
        },
        {
          "name": "executor",
          "role": "input",

  "operation_name": "aclnnAdaptiveAvgPool3d",
  "description": "在指定三维输出shape信息（outputSize）的情况下，完成张量self的3D自适应平均池化计算。aclnnAdaptiveAvgPool3d与aclnnAvgPool3d不同的是，aclnnAdaptiveAvgPool3d只需要指定输出的大小，就可以自动推导出kernel的大小与对应的步长。",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "shape_dependency",
      "params": [
        "self",
        "out"
      ],
      "expr": "out.shape[:-3] == self.shape[:-3]",
      "description": "out除最后三个DHW维外的前置维度必须与self一致。",
      "source": "self",
      "target": [
        "out"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "outputSize",
        "out"
      ],
      "expr": "out.shape[-3] == outputSize[0] and out.shape[-2] == outputSize[1] and out.shape[-1] == outputSize[2]",
      "description": "out的最后三个维度必须分别等于outputSize指定的[Dout, Hout, Wout]。",
      "source": "outputSize",
      "target": [
        "out"
      ]
    },
    {
      "type": "type_equality",
      "params": [
        "self",
        "out"
      ],
      "expr": "self.dtype == out.dtype",
      "description": "out的数据类型必须与self一致。",
      "source": "self",
      "target": [
        "out"
      ]
    },
    {
      "type": "format_equality",
      "params": [
        "self",
        "out"
      ],
      "expr": "self.format == out.format",
      "description": "out的数据格式必须与self一致。",
      "source": "self",
      "target": [
        "out"
      ]
    }
  ],
  "platform_specifics": [
    {
      "platform": "Atlas A3 训练系列产品/Atlas A3 推理系列产品",
      "description": "产品支持情况：是否支持：√",

  "functions": [
    {
      "api_name": "aclnnAdaptiveAvgPool3dGetWorkspaceSize",
      "description": "第一段接口完成入参校验，获取计算所需workspace大小以及包含了算子计算流程的执行器。",
      "parameters": [
        {
          "name": "self",
          "role": "input",
          "type": "aclTensor",
          "is_optional": false,
          "description": "表示待计算的目标张量，Device侧的aclTensor。支持非连续的Tensor，不支持空tensor，shape支持4-5维。数据格式支持NCDHW、ND。Atlas 推理系列产品：数据类型支持FLOAT16、FLOAT32。Atlas A2 训练系列产品/Atlas A2 推理系列产品、Atlas A3 训练系列产品/Atlas A3 推理系列产品：数据类型支持BFLOAT16、FLOAT16、FLOAT32。",
          "format": [
            "NCDHW",
            "ND"
          ]
        },
        {
          "name": "outputSize",
          "role": "input",
          "type": "aclIntArray",
          "is_optional": false,
          "description": "指定输出在DHW维度上的shape大小，Device侧的aclIntArray。数据类型支持INT64，数组长度恒为3。",
          "format": null
        },
        {
          "name": "out",
          "role": "output",
          "type": "aclTensor",
          "is_optional": false,
          "description": "Device侧的aclTensor，与self的数据类型一致；out的shape需要与self的shape和outputSize推导出的shape结果一致。支持非连续的Tensor，数据格式支持NCDHW、ND，且与self一致。Atlas 推理系列产品：数据类型支持FLOAT16、FLOAT32。Atlas A2 训练系列产品/Atlas A2 推理系列产品、Atlas A3 训练系列产品/Atlas A3 推理系列产品：数据类型支持BFLOAT16、FLOAT16、FLOAT32。",
          "format": [
            "NCDHW",
            "ND"
          ]
        },
        {
          "name": "workspaceSize",
          "role": "output",
          "type": "uint64_t",
          "is_optional": false,
          "description": "返回需要在Device侧申请的workspace大小。",
          "format": null
        },
        {
          "name": "executor",
          "role": "output",
          "type": "aclOpExecutor",
          "is_optional": false,
          "description": "返回op执行器，包含了算子计算流程。",
          "format": null
        }
      ]
    },
    {
      "api_name": "aclnnAdaptiveAvgPool3d",
      "description": "第二段接口执行3D自适应平均池化计算，使用第一段接口返回的workspace和executor完成计算。",
      "parameters": [
        {
          "name": "workspace",
          "role": "input",
          "type": "void",
          "is_optional": false,
          "description": "在Device侧申请的workspace内存地址。",
          "format": null
        },
        {
          "name": "workspaceSize",
          "role": "input",
          "type": "uint64_t",
          "is_optional": false,
          "description": "在Device侧申请的workspace大小，由第一段接口aclnnAdaptiveAvgPool3dGetWorkspaceSize获取。",
          "format": null
        },
        {
          "name": "executor",
          "role": "input",
          "type": "aclOpExecutor",
          "is_optional": false,

  "operation_name": "aclnnAdaptiveAvgPool3dBackward",
  "description": "算子功能：[aclnnAdaptiveAvgPool3d](./aclnnAdaptiveAvgPool3d.md) 的反向计算。",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "type_equality",
      "params": [
        "gradOutput",
        "self",
        "out"
      ],
      "expr": "gradOutput.dtype == self.dtype and self.dtype == out.dtype",
      "description": "gradOutput、self 和 out 的数据类型必须一致。",
      "source": null,
      "target": null
    },
    {
      "type": "format_equality",
      "params": [
        "gradOutput",
        "self"
      ],
      "expr": "gradOutput.format == self.format",
      "description": "gradOutput 和 self 的数据格式必须一致。",
      "source": null,
      "target": null
    },
    {
      "type": "shape_dependency",
      "params": [
        "gradOutput",
        "self"
      ],
      "expr": "len(gradOutput.shape) == len(self.shape)",
      "description": "gradOutput 的总维数必须与 self 一致。",
      "source": "self",
      "target": [
        "gradOutput"
      ]
    },
    {
      "type": "shape_equality",
      "params": [
        "out",
        "self"
      ],
      "expr": "out.shape == self.shape",
      "description": "out 的 shape 必须与 self 完全一致。",
      "source": null,
      "target": null
    },
    {
      "type": "shape_value_dependency",
      "params": [
        "gradOutput",
        "self"
      ],
      "expr": "gradOutput.shape[:-3] == self.shape[:-3]",
      "description": "gradOutput 的前置 N/C 维度取值必须与 self 对应维度一致。",
      "source": "self",
      "target": [
        "gradOutput"
      ]
    }
  ],

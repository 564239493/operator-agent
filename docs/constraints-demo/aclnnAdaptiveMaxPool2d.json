      "description": "是否支持：√",
      "constraint_detail": ""
    },
    {
      "platform": "<term>Atlas 训练系列产品</term>",
      "description": "<term>Atlas 训练系列产品</term>：参数`self`、`outputOut`、`indicesOut`的数据类型不支持BFLOAT16。",
      "constraint_detail": "self.dtype != BFLOAT16 and outputOut.dtype != BFLOAT16"
    }
  ],
  "other_parameters": [
    {
      "name": "N",
      "type": "int64_t",
      "description": "输入与输出张量的批量维度，仅在4维shape中出现。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "(len(self.shape) == 3 and len(outputOut.shape) == 3 and len(indicesOut.shape) == 3) or (len(self.shape) == 4 and len(outputOut.shape) == 4 and len(indicesOut.shape) == 4 and N == self.shape[0] and outputOut.shape[0] == N and indicesOut.shape[0] == N)"
        }
      ]
    },
    {
      "name": "C",
      "type": "int64_t",
      "description": "输入与输出张量的通道维度。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "(len(self.shape) == 3 and len(outputOut.shape) == 3 and len(indicesOut.shape) == 3 and C == self.shape[0] and outputOut.shape[0] == C and indicesOut.shape[0] == C) or (len(self.shape) == 4 and self.format == 'NCHW' and len(outputOut.shape) == 4 and len(indicesOut.shape) == 4 and C == self.shape[1] and outputOut.shape[1] == C and indicesOut.shape[1] == C and C >= 1) or (len(self.shape) == 4 and self.format == 'NHWC' and len(outputOut.shape) == 4 and len(indicesOut.shape) == 4 and C == self.shape[3] and outputOut.shape[3] == C and indicesOut.shape[3] == C and C >= 1)"
        }
      ]
    },
    {
      "name": "Hin",
      "type": "int64_t",
      "description": "输入张量的高度维度。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "(len(self.shape) == 4 and self.format == 'NCHW' and Hin == self.shape[2] and Hin >= 1) or (len(self.shape) == 3 and Hin == self.shape[1] and Hin >= 1) or (len(self.shape) == 4 and self.format == 'NHWC' and Hin == self.shape[1] and Hin >= 1)"
        }
      ]
    },
    {
      "name": "Win",
      "type": "int64_t",
      "description": "输入张量的宽度维度。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "(len(self.shape) == 4 and self.format == 'NCHW' and Win == self.shape[3] and Win >= 1) or (len(self.shape) == 3 and Win == self.shape[2] and Win >= 1) or (len(self.shape) == 4 and self.format == 'NHWC' and Win == self.shape[2] and Win >= 1)"
        }
      ]
    },
    {
      "name": "Hout",
      "type": "int64_t",
      "description": "输出张量的高度维度，对应outputSize的第1个元素。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "len(outputSize) == 2 and Hout == outputSize[0] and Hout >= 1 and ((len(self.shape) == 4 and self.format == 'NCHW' and len(outputOut.shape) == 4 and len(indicesOut.shape) == 4 and outputOut.shape[2] == Hout and indicesOut.shape[2] == Hout) or (len(self.shape) == 3 and len(outputOut.shape) == 3 and len(indicesOut.shape) == 3 and outputOut.shape[1] == Hout and indicesOut.shape[1] == Hout) or (len(self.shape) == 4 and self.format == 'NHWC' and len(outputOut.shape) == 4 and len(indicesOut.shape) == 4 and outputOut.shape[1] == Hout and indicesOut.shape[1] == Hout))"
        }
      ]
    },
    {
      "name": "Wout",
      "type": "int64_t",
      "description": "输出张量的宽度维度，对应outputSize的第2个元素。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "len(outputSize) == 2 and Wout == outputSize[1] and Wout >= 1 and ((len(self.shape) == 4 and self.format == 'NCHW' and len(outputOut.shape) == 4 and len(indicesOut.shape) == 4 and outputOut.shape[3] == Wout and indicesOut.shape[3] == Wout) or (len(self.shape) == 3 and len(outputOut.shape) == 3 and len(indicesOut.shape) == 3 and outputOut.shape[2] == Wout and indicesOut.shape[2] == Wout) or (len(self.shape) == 4 and self.format == 'NHWC' and len(outputOut.shape) == 4 and len(indicesOut.shape) == 4 and outputOut.shape[2] == Wout and indicesOut.shape[2] == Wout))"
        }
      ]
    }
  ],
  "functions": [
    {
      "api_name": "aclnnAdaptiveMaxPool2dGetWorkspaceSize",
      "description": "第一段接口，获取计算所需workspace大小以及包含了算子计算流程的执行器。",
      "parameters": [
        {
          "name": "self",
          "role": "input",
          "type": "aclTensor",
          "is_optional": false,
          "description": "待计算张量。",
          "format": [
            "NCHW",
            "NCL",
            "NHWC"
          ]
        },
        {
          "name": "outputSize",
          "role": "input",
          "type": "aclIntArray",
          "is_optional": false,
          "description": "表示输出结果在H和W维度上的空间大小。",
          "format": null
        },
        {
          "name": "outputOut",
          "role": "output",
          "type": "aclTensor",
          "is_optional": false,
          "description": "池化后的结果。",
          "format": [
            "NCHW",
            "NCL",
            "NHWC"
          ]
        },
        {
          "name": "indicesOut",
          "role": "output",
          "type": "aclTensor",
          "is_optional": false,
          "description": "outputOut元素在输入self中的索引位置。",
          "format": [
            "NCHW",
            "NCL",
            "NHWC"
          ]
        },
        {
          "name": "workspaceSize",
          "role": "output",
          "type": "uint64_t",
          "is_optional": false,
          "description": "返回需要在Device侧申请的workspace大小。",
          "format": null
        },
        {
          "name": "executor",
          "role": "output",
          "type": "aclOpExecutor",
          "is_optional": false,
          "description": "返回op执行器，包含了算子计算流程。",
          "format": null
        }
      ]
    },
    {
      "api_name": "aclnnAdaptiveMaxPool2d",

  "operation_name": "aclnnAdaptiveMaxPool2d",
  "description": "根据输入的outputSize计算每次kernel的大小，对输入self进行2维最大池化操作，输出池化后的值out和索引indices。aclnnAdaptiveMaxPool2d与aclnnMaxPool2d的区别在于，只需指定outputSize大小，并按outputSize的大小来划分pooling区域。",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "type_equality",
      "params": [
        "self",
        "outputOut"
      ],
      "expr": "self.dtype == outputOut.dtype",
      "description": "参数self与outputOut的数据类型必须一致。",
      "source": null,
      "target": null
    },
    {
      "type": "shape_equality",
      "params": [
        "outputOut",
        "indicesOut"
      ],
      "expr": "outputOut.shape == indicesOut.shape",
      "description": "参数outputOut与indicesOut的shape必须一致。",
      "source": null,
      "target": null
    },
    {
      "type": "shape_dependency",
      "params": [
        "self",
        "outputSize",
        "outputOut"
      ],
      "expr": "(len(self.shape) == 3 and outputOut.shape == (self.shape[0], outputSize[0], outputSize[1])) or (len(self.shape) == 4 and outputOut.shape == (self.shape[0], self.shape[1], outputSize[0], outputSize[1])) or (len(self.shape) == 4 and outputOut.shape == (self.shape[0], outputSize[0], outputSize[1], self.shape[3]))",
      "description": "outputOut的shape由self的shape和outputSize共同决定：3维输入时为(C, Hout, Wout)，4维输入时为(N, C, Hout, Wout)或(N, Hout, Wout, C)。",
      "source": null,
      "target": [
        "outputOut"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "self",
        "outputSize",
        "indicesOut"
      ],
      "expr": "(len(self.shape) == 3 and indicesOut.shape == (self.shape[0], outputSize[0], outputSize[1])) or (len(self.shape) == 4 and indicesOut.shape == (self.shape[0], self.shape[1], outputSize[0], outputSize[1])) or (len(self.shape) == 4 and indicesOut.shape == (self.shape[0], outputSize[0], outputSize[1], self.shape[3]))",
      "description": "indicesOut的shape由self的shape和outputSize共同决定：3维输入时为(C, Hout, Wout)，4维输入时为(N, C, Hout, Wout)或(N, Hout, Wout, C)。",
      "source": null,
      "target": [
        "indicesOut"
      ]
    }
  ],
  "platform_specifics": [
    {
      "platform": "<term>Atlas A3 训练系列产品/Atlas A3 推理系列产品</term>",
      "description": "是否支持：√",

      "constraint_detail": "supported == True"
    },
    {
      "platform": "Atlas 200I/500 A2 推理产品",
      "description": "是否支持：×",
      "constraint_detail": "supported == False"
    },
    {
      "platform": "Atlas 推理系列产品",
      "description": "是否支持：×",
      "constraint_detail": "supported == False"
    },
    {
      "platform": "Atlas 训练系列产品",
      "description": "是否支持：×",
      "constraint_detail": "supported == False"
    }
  ],
  "other_parameters": [
    {
      "name": "N",
      "type": "int64_t",
      "description": "输入和输出按 NCHW 处理时的 batch 维度；当输入为 3 维时在第 0 维补 1。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "((len(self.shape) == 4 and len(gradInput.shape) == 4 and len(gradOutput.shape) == 4 and len(indices.shape) == 4 and self.shape[0] == N and gradInput.shape[0] == N and gradOutput.shape[0] == N and indices.shape[0] == N) or (len(self.shape) == 3 and len(gradInput.shape) == 3 and len(gradOutput.shape) == 3 and len(indices.shape) == 3 and N == 1))"
        }
      ]
    },
    {
      "name": "C",
      "type": "int64_t",
      "description": "输入和输出按 NCHW 处理时的通道维度。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "self.shape[-3] == C and gradInput.shape[-3] == C and gradOutput.shape[-3] == C and indices.shape[-3] == C"
        }
      ]
    },
    {
      "name": "H",
      "type": "int64_t",
      "description": "self 和 gradInput 的高度维度。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "self.shape[-2] == H and gradInput.shape[-2] == H and H * W <= 2147483647"
        },
        {
          "platform": "All",
          "value": [],
          "rule": "(H % H_o == 0 and W % W_o == 0) or H <= 16777216"
        }
      ]
    },
    {
      "name": "W",
      "type": "int64_t",
      "description": "self 和 gradInput 的宽度维度。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "self.shape[-1] == W and gradInput.shape[-1] == W and H * W <= 2147483647"
        },
        {
          "platform": "All",
          "value": [],
          "rule": "(H % H_o == 0 and W % W_o == 0) or W <= 16777216"
        }
      ]
    },
    {
      "name": "H_o",
      "type": "int64_t",
      "description": "gradOutput 和 indices 的高度维度，对应 outputSize[0]。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "gradOutput.shape[-2] == H_o and indices.shape[-2] == H_o and ((H % H_o == 0 and W % W_o == 0) or H_o <= 16777216)"
        }
      ]
    },
    {
      "name": "W_o",
      "type": "int64_t",
      "description": "gradOutput 和 indices 的宽度维度，对应 outputSize[1]。",
      "constraints": [
        {
          "platform": "All",
          "value": [],
          "rule": "gradOutput.shape[-1] == W_o and indices.shape[-1] == W_o and ((H % H_o == 0 and W % W_o == 0) or W_o <= 16777216)"
        }
      ]
    }
  ],
  "functions": [
    {
      "api_name": "aclnnAdaptiveMaxPool2dBackwardGetWorkspaceSize",
      "description": "获取计算所需的workspace大小以及包含算子计算流程的执行器，必须在执行接口前调用。第一段接口同时完成入参校验。",
      "parameters": [
        {
          "name": "gradOutput",
          "role": "input",
          "type": "aclTensor",
          "is_optional": false,
          "description": "梯度Tensor，Device侧aclTensor。数据类型支持FLOAT32、FLOAT16、BFLOAT16，和正向的输出shape一致。支持非连续的Tensor，数据格式支持ND，当输入是4维时，内部按照NCHW处理，当输入是3维时，在0维度处补1，内部按照NCHW处理。",
          "format": "ND"
        },
        {
          "name": "self",
          "role": "input",
          "type": "aclTensor",
          "is_optional": false,
          "description": "正向的输入Tensor，Device侧aclTensor。数据类型支持FLOAT32、FLOAT16、BFLOAT16。支持非连续的Tensor，数据格式支持ND，当输入是4维时，内部按照NCHW处理，当输入是3维时，在0维度处补1，内部按照NCHW处理，与gradOutput一致。",
          "format": "ND"
        },
        {
          "name": "indices",
          "role": "input",
          "type": "aclTensor",
          "is_optional": false,
          "description": "输入Tensor，是Device侧aclTensor。数据类型支持INT32，INT64。正向输入中最大元素的索引位置。数据格式与gradOutput保持一致。shape与gradOutput一致。",
          "format": "ND"
        },
        {
          "name": "gradInput",
          "role": "output",
          "type": "aclTensor",
          "is_optional": false,
          "description": "反向输出Tensor，是Device侧aclTensor。数据类型支持FLOAT32、FLOAT16、BFLOAT16，shape与self保持一致。支持非连续的Tensor，数据格式与self保持一致。",
          "format": "ND"
        },
        {
          "name": "workspaceSize",
          "role": "output",
          "type": "uint64_t",
          "is_optional": false,
          "description": "返回需要在Device侧申请的workspace大小。",
          "format": null
        },
        {
          "name": "executor",
          "role": "output",
          "type": "aclOpExecutor",
          "is_optional": false,
          "description": "返回op执行器，包含了算子计算流程。",
          "format": null
        }
      ]
    },
    {
      "api_name": "aclnnAdaptiveMaxPool2dBackward",
      "description": "执行自适应最大池化2d反向传播计算，使用第一段接口返回的workspace和executor在指定Stream上执行。",
      "parameters": [
        {
          "name": "workspace",
          "role": "input",
          "type": "void",
          "is_optional": false,
          "description": "在Device侧申请的workspace内存地址。",
          "format": null
        },
        {
          "name": "workspaceSize",
          "role": "input",
          "type": "uint64_t",
          "is_optional": false,
          "description": "在Device侧申请的workspace大小，由第一段接口aclnnAdaptiveMaxPool2dBackwardGetWorkspaceSize获取。",
          "format": null
        },
        {
          "name": "executor",

        "gamma"
      ],
      "expr": "len(gamma.shape) <= len(dy.shape) and gamma.shape == dy.shape[-len(gamma.shape):]",
      "description": "gamma的shape必须等于dy需要做norm的各维度。",
      "source": "dy",
      "target": [

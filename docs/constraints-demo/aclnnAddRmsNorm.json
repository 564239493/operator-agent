  "operation_name": "aclnnAddRmsNorm",
  "description": "接口功能：RmsNorm算子是大模型常用的归一化操作，相比LayerNorm算子，其去掉了减去均值的部分。AddRmsNorm算子将RmsNorm前的Add算子融合起来，减少搬入搬出操作。\n计算公式：x_i=x1_{i}+x2_{i}；RmsNorm(x_i)=x_i/Rms(x) * gamma_i，其中 Rms(x)=sqrt((1/n) * sum_{i=1}^n x_i^2 + epsilon)。",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "shape_equality",
      "params": [
        "x1",
        "x2",
        "yOut",
        "xOut"
      ],
      "expr": "x1.shape == x2.shape == yOut.shape == xOut.shape",
      "description": "输入x1、x2与输出yOut、xOut的shape必须一致。",
      "source": null,
      "target": null
    },
    {
      "type": "type_equality",
      "params": [
        "x1",
        "x2",
        "gamma",
        "yOut",
        "xOut"
      ],
      "expr": "x1.dtype == x2.dtype == gamma.dtype == yOut.dtype == xOut.dtype",
      "description": "输入x1、x2、gamma与输出yOut、xOut的数据类型必须一致。",
      "source": null,
      "target": null
    },
    {
      "type": "shape_dependency",
      "params": [
        "x1",
        "gamma"
      ],
      "expr": "len(gamma.shape) <= len(x1.shape) and all(gamma.shape[i] == x1.shape[len(x1.shape) - len(gamma.shape) + i] for i in range(len(gamma.shape)))",
      "description": "gamma的shape必须与x1的后几维一致，这些后几维对应x1需要做norm的维度。",
      "source": "x1",
      "target": [
        "gamma"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "x1",
        "gamma",
        "rstdOut"

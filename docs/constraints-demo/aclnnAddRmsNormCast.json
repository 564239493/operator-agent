  "operation_name": "aclnnAddRmsNormCast",
  "description": "接口功能：RmsNorm算子是大模型常用的归一化操作，AddRmsNormCast算子将AddRmsNorm后的Cast算子融合起来，减少搬入搬出操作。\n计算公式：\n$$\nx_i=x1_{i}+x2_{i}\n$$\n$$\ny2Out=\\operatorname{RmsNorm}(x_i)=\\frac{1}{\\operatorname{Rms}(\\mathbf{x})} * x_i *g_i, \\quad \\text { where } \\operatorname{Rms}(\\mathbf{x})=\\sqrt{\\frac{1}{n} \\sum_{i=1}^n x_i^2+eps}\n$$\n$$\ny1Out=float(y2Out)\n$$",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "shape_equality",
      "params": [
        "x1",
        "x2"
      ],
      "expr": "x2.shape == x1.shape",
      "description": "输入x2的shape必须与x1一致。",
      "source": "x1",
      "target": [
        "x2"
      ]
    },
    {
      "type": "type_equality",
      "params": [
        "x1",
        "x2"
      ],
      "expr": "x2.dtype == x1.dtype",
      "description": "输入x2的数据类型必须与x1一致。",
      "source": "x1",
      "target": [
        "x2"
      ]
    },
    {
      "type": "type_equality",
      "params": [
        "x1",
        "gamma"
      ],
      "expr": "gamma.dtype == x1.dtype",
      "description": "输入gamma的数据类型必须与x1一致。",
      "source": "x1",
      "target": [
        "gamma"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "x1",
        "gamma"
      ],
      "expr": "len(gamma.shape) <= len(x1.shape) and x1.shape[len(x1.shape) - len(gamma.shape):] == gamma.shape",
      "description": "gamma的shape必须与x1后几维一致，这些后几维是x1需要做norm的维度。",
      "source": "x1",
      "target": [
        "gamma"
      ]
    },
    {
      "type": "shape_equality",
      "params": [
        "x1",
        "y1Out"
      ],
      "expr": "y1Out.shape == x1.shape",
      "description": "输出y1Out的shape必须与x1一致。",
      "source": "x1",
      "target": [
        "y1Out"
      ]
    },
    {
      "type": "format_equality",
      "params": [
        "x1",
        "y1Out"
      ],
      "expr": "y1Out.format == x1.format",
      "description": "输出y1Out的数据格式必须与x1一致。",
      "source": "x1",
      "target": [
        "y1Out"
      ]
    },
    {
      "type": "shape_equality",
      "params": [
        "x1",
        "y2Out"
      ],
      "expr": "y2Out.shape == x1.shape",
      "description": "输出y2Out的shape必须与x1一致。",
      "source": "x1",
      "target": [
        "y2Out"
      ]

      "description": "cubeMathType=1，当输入数据类型为FLOAT32时，会转换为HFLOAT32计算，当输入为其他数据类型时不做处理；",
      "constraint_detail": "(cubeMathType != 1) or (compute_dtype == (\"HFLOAT32\" if input_dtype == \"FLOAT32\" else input_dtype))"
    },
    {
      "platform": "Atlas A2 训练系列产品/Atlas A2 推理系列产品、Atlas A3 训练系列产品/Atlas A3 推理系列产品",
      "description": "cubeMathType=2，当输入数据类型为BFLOAT16时不支持该选项；",
      "constraint_detail": "not (input_dtype == \"BFLOAT16\" and cubeMathType == 2)"
    },
    {
      "platform": "Atlas A2 训练系列产品/Atlas A2 推理系列产品、Atlas A3 训练系列产品/Atlas A3 推理系列产品",
      "description": "cubeMathType=3，当输入数据类型为FLOAT32时，会转换为HFLOAT32计算，当输入为其他数据类型时不支持该选项。",
      "constraint_detail": "(cubeMathType != 3) or (input_dtype == \"FLOAT32\" and compute_dtype == \"HFLOAT32\")"
    },
    {
      "platform": "Atlas 训练系列产品、Atlas 推理系列产品",
      "description": "aclnnAddmm&aclnnInplaceAddmm默认非确定性实现，支持通过aclrtCtxSetSysParamOpt开启确定性。",
      "constraint_detail": "deterministic_default == False and can_enable_deterministic == True"
    },
    {
      "platform": "Atlas 训练系列产品、Atlas 推理系列产品",
      "description": "当开启强一致性计算功能时，计算结果时确定的，多次执行将产生相同的输出。此外，计算结果与数据的位置无关。",
      "constraint_detail": "result_deterministic_when_strong_consistency == True and result_independent_of_data_position_when_strong_consistency == True"
    },
    {
      "platform": "Atlas 训练系列产品、Atlas 推理系列产品",
      "description": "aclnnAddmm&aclnnInplaceAddmm默认非一致性实现，支持通过aclrtCtxSetSysParamOpt开启一致性。",
      "constraint_detail": "consistency_default == False and can_enable_consistency == True"
    }
  ],

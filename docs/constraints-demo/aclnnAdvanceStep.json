  "operation_name": "aclnnAdvanceStep",
  "description": "vLLM是一个高性能的LLM推理和服务框架，专注于优化大规模语言模型的推理效率。它的核心特点包括PageAttention和高效内存管理。advance_step算子的主要作用是推进推理步骤，即在每个生成步骤中更新模型的状态并生成新的inputTokens、inputPositions、seqLens和slotMapping，为vLLM的推理提升效率。\n\nblockIdx是当前代码被执行的核的index。\nblockTablesStride = blockTables.stride(0)\ninputTokens[blockIdx] = sampledTokenIds[blockIdx]\ninputPositions[blockIdx] = seqLens[blockIdx]\nseqLens[blockIdx] = seqLens[blockIdx] + 1\nslotMapping[blockIdx] = (blockTables[blockIdx] + blockTablesStride * blockIdx) * blockSize + (seqLens[blockIdx] \\% blockSize)",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "shape_dependency",
      "params": [
        "numSeqs",
        "inputTokens"
      ],
      "expr": "inputTokens.shape[0] == numSeqs",
      "description": "inputTokens 的第一维长度必须等于 numSeqs。",
      "source": "numSeqs",
      "target": [
        "inputTokens"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "numSeqs",
        "inputPositions"
      ],
      "expr": "inputPositions.shape[0] == numSeqs",
      "description": "inputPositions 的第一维长度必须等于 numSeqs。",
      "source": "numSeqs",
      "target": [
        "inputPositions"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "numSeqs",
        "seqLens"
      ],
      "expr": "seqLens.shape[0] == numSeqs",
      "description": "seqLens 的第一维长度必须等于 numSeqs。",
      "source": "numSeqs",
      "target": [
        "seqLens"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "numSeqs",
        "slotMapping"
      ],
      "expr": "slotMapping.shape[0] == numSeqs",
      "description": "slotMapping 的第一维长度必须等于 numSeqs。",
      "source": "numSeqs",
      "target": [
        "slotMapping"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "numSeqs",
        "blockTables"
      ],
      "expr": "blockTables.shape[0] == numSeqs",
      "description": "blockTables 的第一维长度必须等于 numSeqs。",
      "source": "numSeqs",
      "target": [
        "blockTables"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "numQueries",
        "sampledTokenIds"
      ],
      "expr": "sampledTokenIds.shape[0] == numQueries",
      "description": "sampledTokenIds 的第一维长度必须等于 numQueries。",
      "source": "numQueries",
      "target": [
        "sampledTokenIds"
      ]
    },
    {
      "type": "value_dependency",
      "params": [
        "numSeqs",
        "numQueries"
      ],

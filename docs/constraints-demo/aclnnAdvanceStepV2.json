  "operation_name": "aclnnAdvanceStepV2",
  "description": "接口功能：\n\nvLLM是一个高性能的LLM推理和服务框架，专注于优化大规模语言模型的推理效率。它的核心特点包括PageAttention和高效内存管理。advance_step算子的主要作用是推进推理步骤，即在每个生成步骤中更新模型的状态并生成新的inputTokens、inputPositions、seqLens和slotMapping，为vLLM的推理提升效率。\n\n计算公式：\n\nblockIdx是当前代码被执行的核的index。\nblockTablesStride = blockTables.stride(0)\ninputTokens[blockIdx] = sampledTokenIds[blockIdx]\ninputPositions[blockIdx] = seqLens[blockIdx]\nseqLens[blockIdx] = seqLens[blockIdx] + 1\nslotMapping[blockIdx] = (blockTables[blockIdx] + blockTablesStride * blockIdx) * blockSize + (seqLens[blockIdx] % blockSize)",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "shape_value_dependency",
      "params": [
        "inputTokens",
        "inputPositions",
        "seqLens",
        "slotMapping",
        "blockTables",
        "specToken",
        "acceptedNum",
        "numSeqs"
      ],
      "expr": "inputTokens.shape[0] == inputPositions.shape[0] == seqLens.shape[0] == slotMapping.shape[0] == blockTables.shape[0] == specToken.shape[0] == acceptedNum.shape[0] == numSeqs",
      "description": "inputTokens、inputPositions、seqLens、slotMapping、blockTables、specToken和acceptedNum的第一维长度必须都等于numSeqs。",
      "source": null,
      "target": null
    },
    {
      "type": "shape_value_dependency",
      "params": [
        "sampledTokenIds",
        "numQueries"
      ],
      "expr": "sampledTokenIds.shape[0] == numQueries",
      "description": "sampledTokenIds的第一维长度必须等于numQueries。",
      "source": null,
      "target": null
    },
    {
      "type": "shape_value_dependency",
      "params": [
        "inputTokens",
        "specToken"
      ],
      "expr": "inputTokens.shape[1] == specToken.shape[1] + 1",
      "description": "inputTokens的第二维长度必须比specToken的第二维长度大1。",
      "source": null,
      "target": null
    },
    {
      "type": "shape_value_dependency",
      "params": [
        "sampledTokenIds",
        "specToken"
      ],
      "expr": "sampledTokenIds.shape[1] == specToken.shape[1] + 1",
      "description": "sampledTokenIds的第二维长度必须比specToken的第二维长度大1。",
      "source": null,
      "target": null
    },
    {
      "type": "shape_value_dependency",
      "params": [
        "blockTables",
        "seqLens",
        "blockSize"
      ],
      "expr": "blockTables.shape[1] > (max(seqLens) / blockSize)",
      "description": "blockTables的第二维长度必须大于seqLens中最大值除以blockSize的结果。",
      "source": null,
      "target": null
    }
  ],
  "platform_specifics": [

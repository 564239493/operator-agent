  "operation_name": "aclnnApplyAdamW",
  "description": "算子功能：实现adamW优化器功能。\n\n计算公式：\n\ng_t=\\begin{cases}-g_t\n& \\text{ if } maxmize= true\\\\\ng_t  & \\text{ if } maxmize=false\n\\end{cases}\n\nm_{t}=\\beta_{1} m_{t-1}+\\left(1-\\beta_{1}\\right) g_{t}\n\nv_{t}=\\beta_{2} v_{t-1}+\\left(1-\\beta_{2}\\right) g_{t}^{2}\n\n\\beta_{1}^{t}=\\beta_{1}^{t-1}\\times\\beta_{1}\n\n\\beta_{2}^{t}=\\beta_{2}^{t-1}\\times\\beta_{2}\n\nv_t=\\begin{cases}\\max(maxGradNorm, v_t)\n& \\text{ if } amsgrad = true\\\\\nv_t  & \\text{ if } amsgrad = false\n\\end{cases}\n\n\\hat{m}_{t}=\\frac{m_{t}}{1-\\beta_{1}^{t}}\n\n\\hat{v}_{t}=\\frac{v_{t}}{1-\\beta_{2}^{t}}\n\n\\theta_{t+1}=\\theta_{t}-\\frac{\\eta}{\\sqrt{\\hat{v}_{t}}+\\epsilon} \\hat{m}_{t}-\\eta \\cdot \\lambda \\cdot \\theta_{t-1}",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "type_equality",
      "params": [
        "varRef",
        "mRef",
        "vRef",
        "beta1Power",
        "beta2Power",
        "lr",
        "weightDecay",
        "beta1",
        "beta2",
        "eps",
        "grad"
      ],
      "expr": "varRef.dtype == mRef.dtype == vRef.dtype == beta1Power.dtype == beta2Power.dtype == lr.dtype == weightDecay.dtype == beta1.dtype == beta2.dtype == eps.dtype == grad.dtype",
      "description": "输入张量 varRef、mRef、vRef、beta1Power、beta2Power、lr、weightDecay、beta1、beta2、eps 和 grad 的数据类型必须一致。",
      "source": "varRef",
      "target": [
        "mRef",
        "vRef",
        "beta1Power",
        "beta2Power",
        "lr",
        "weightDecay",
        "beta1",
        "beta2",
        "eps",
        "grad"
      ]
    },
    {
      "type": "shape_equality",
      "params": [
        "varRef",
        "mRef",
        "vRef",
        "grad"
      ],
      "expr": "varRef.shape == mRef.shape == vRef.shape == grad.shape",
      "description": "输入张量 varRef、mRef、vRef 和 grad 的 shape 必须一致。",
      "source": "varRef",
      "target": [
        "mRef",
        "vRef",
        "grad"
      ]
    },
    {
      "type": "presence_dependency",
      "params": [
        "amsgrad",
        "maxGradNormOptional"
      ],
      "expr": "(not amsgrad) or (maxGradNormOptional is not None)",
      "description": "当 amsgrad 为 true 时，maxGradNormOptional 参数必选；当 amsgrad 为 false 时，该参数可选。",
      "source": "amsgrad",
      "target": [
        "maxGradNormOptional"
      ]
    },
    {
      "type": "shape_equality",
      "params": [
        "maxGradNormOptional",
        "varRef"
      ],
      "expr": "(maxGradNormOptional is None) or (maxGradNormOptional.shape == varRef.shape)",
      "description": "当提供 maxGradNormOptional 时，其 shape 必须与 varRef 一致。",
      "source": "varRef",
      "target": [
        "maxGradNormOptional"
      ]
    },
    {
      "type": "type_equality",
      "params": [
        "maxGradNormOptional",
        "varRef"
      ],
      "expr": "(maxGradNormOptional is None) or (maxGradNormOptional.dtype == varRef.dtype)",
      "description": "当提供 maxGradNormOptional 时，其数据类型必须与 varRef 一致。",
      "source": "varRef",
      "target": [
        "maxGradNormOptional"
      ]
    }
  ],

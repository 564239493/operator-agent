  "operation_name": "aclnnApplyAdamWQuant",
  "description": "对优化器输入的m和v作为索引，取出各自qmap中的值，乘以每个blockSize对应的absmax进行反量化，而后实现adamW优化器功能，更新后的m和v每blockSize中取一个最大值，每blockSize个m和v对应一个absmax，进行一次norm归一化，利用二分法找到对应m和v对应qmap中的索引作为输出，absmax也作为下一轮量化的输入。\n\n优化器计算公式：\n$$\nm_{t}=\\beta_{1} m_{t-1}+\\left(1-\\beta_{1}\\right) g_{t} \\\\\n$$\n\n$$\nv_{t}=\\beta_{2} v_{t-1}+\\left(1-\\beta_{2}\\right) g_{t}^{2}\n$$\n\n$$\n\\hat{m}_{t}=\\frac{m_{t}}{1-\\beta_{1}^{t}} \\\\\n$$\n\n$$\n\\hat{v}_{t}=\\frac{v_{t}}{1-\\beta_{2}^{t}} \\\\\n$$\n\n$$\n\\theta_{t+1}=\\theta_{t}-\\frac{\\eta}{\\sqrt{\\hat{v}_{t}}+\\epsilon} \\hat{m}_{t}-\\eta \\cdot \\lambda \\cdot \\theta_{t-1}\n$$",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "type_equality",
      "params": [
        "grad",
        "varRef"
      ],
      "expr": "grad.dtype == varRef.dtype",
      "description": "grad和varRef的数据类型必须保持一致。",
      "source": null,
      "target": null
    },
    {
      "type": "shape_equality",
      "params": [
        "varRef",
        "grad",
        "mRef",
        "vRef"
      ],
      "expr": "varRef.shape == grad.shape == mRef.shape == vRef.shape",
      "description": "varRef、grad、mRef和vRef的shape必须完全相同。",
      "source": null,
      "target": null
    },
    {
      "type": "shape_dependency",
      "params": [
        "varRef",
        "absmaxMRef",
        "blockSize"
      ],
      "expr": "absmaxMRef.size == varRef.size / blockSize",
      "description": "absmaxMRef的元素个数由varRef的元素个数和blockSize共同决定，满足absmaxMRef.size = varRef.size / blockSize。",
      "source": "varRef",
      "target": [
        "absmaxMRef"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "varRef",
        "absmaxVRef",
        "blockSize"
      ],
      "expr": "absmaxVRef.size == varRef.size / blockSize",
      "description": "absmaxVRef的元素个数由varRef的元素个数和blockSize共同决定，满足absmaxVRef.size = varRef.size / blockSize。",
      "source": "varRef",
      "target": [
        "absmaxVRef"
      ]
    }
  ],

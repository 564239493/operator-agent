  "operation_name": "aclnnApplyAdamWV2",
  "description": "接口功能：实现adamW优化器功能。\n\n计算公式：\n\n$$\nm_{t}=\\beta_{1} m_{t-1}+\\left(1-\\beta_{1}\\right) g_{t} \\\\\n$$\n\n$$\nv_{t}=\\beta_{2} v_{t-1}+\\left(1-\\beta_{2}\\right) g_{t}^{2}\n$$\n\n$$\n\\hat{m}_{t}=\\frac{m_{t}}{1-\\beta_{1}^{t}} \\\\\n$$\n\n$$\n\\hat{v}_{t}=\\frac{v_{t}}{1-\\beta_{2}^{t}} \\\\\n$$\n\n$$\n\\theta_{t+1}=\\theta_{t}-\\frac{\\eta}{\\sqrt{\\hat{v}_{t}}+\\epsilon} \\hat{m}_{t}-\\eta \\cdot \\lambda \\cdot \\theta_{t-1}\n$$",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "type_equality",
      "params": [
        "varRef",
        "mRef",
        "vRef",
        "grad"
      ],
      "expr": "varRef.dtype == mRef.dtype == vRef.dtype == grad.dtype",
      "description": "varRef、mRef、vRef和grad的数据类型必须一致。",
      "source": "varRef",
      "target": [
        "mRef",
        "vRef",
        "grad"
      ]
    },
    {
      "type": "type_equality",
      "params": [
        "varRef",
        "maxGradNormOptionalRef"
      ],
      "expr": "(maxGradNormOptionalRef is None) or (maxGradNormOptionalRef.dtype == varRef.dtype)",
      "description": "maxGradNormOptionalRef存在时，其数据类型必须与varRef一致。",
      "source": "varRef",
      "target": [
        "maxGradNormOptionalRef"
      ]
    },
    {
      "type": "shape_equality",
      "params": [
        "varRef",
        "mRef",
        "vRef",
        "grad"
      ],
      "expr": "varRef.shape == mRef.shape == vRef.shape == grad.shape",
      "description": "varRef、mRef、vRef和grad的shape必须一致。",
      "source": "varRef",
      "target": [
        "mRef",
        "vRef",
        "grad"
      ]
    },
    {
      "type": "shape_equality",
      "params": [
        "varRef",
        "maxGradNormOptionalRef"
      ],
      "expr": "(maxGradNormOptionalRef is None) or (maxGradNormOptionalRef.shape == varRef.shape)",
      "description": "maxGradNormOptionalRef存在时，其shape必须与varRef一致。",
      "source": "varRef",
      "target": [
        "maxGradNormOptionalRef"
      ]
    },
    {
      "type": "presence_dependency",
      "params": [
        "amsgrad",
        "maxGradNormOptionalRef"
      ],
      "expr": "(not amsgrad) or (maxGradNormOptionalRef is not None)",
      "description": "当amsgrad为true时，maxGradNormOptionalRef必须提供。",
      "source": "amsgrad",
      "target": [
        "maxGradNormOptionalRef"
      ]
    }
  ],

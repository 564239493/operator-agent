  "operation_name": "aclnnAscendAntiQuant",
  "description": "接口功能：对输入x进行反量化操作。计算公式：sqrtMode为false时，计算公式为：y = float16((x+offset) * scale)；sqrtMode为true时，计算公式为：y = float16((x+offset) * scale * scale)。",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "shape_dependency",
      "params": [
        "x",
        "scale"
      ],
      "expr": "(scale.shape[0] == 1) or ((len(x.shape) > 0) and (x.dtype in ['INT4', 'INT8']) and (scale.shape[0] == x.shape[-1])) or ((len(x.shape) > 0) and (x.dtype == 'INT32') and (scale.shape[0] == x.shape[-1] * 8))",
      "description": "scale 的长度可以为 1；否则当 x 为 INT4 或 INT8 时，scale.shape[0] 必须等于 x 的尾轴大小，当 x 为 INT32 时必须等于 x 的尾轴大小的 8 倍。",
      "source": "x",
      "target": [
        "scale"
      ]
    },
    {
      "type": "shape_equality",
      "params": [
        "scale",
        "offset"
      ],
      "expr": "offset.shape == scale.shape",
      "description": "offset 的 shape 必须与 scale 一致。",
      "source": "scale",
      "target": [
        "offset"
      ]
    },
    {
      "type": "type_equality",
      "params": [
        "scale",
        "offset"
      ],
      "expr": "offset.dtype == scale.dtype",
      "description": "offset 的数据类型必须与 scale 一致。",
      "source": "scale",
      "target": [
        "offset"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "x",
        "y"
      ],
      "expr": "((x.dtype in ['INT4', 'INT8']) and (y.shape == x.shape)) or ((len(x.shape) > 0) and (x.dtype == 'INT32') and (y.shape[:-1] == x.shape[:-1]) and (y.shape[-1] == x.shape[-1] * 8))",
      "description": "当 x 为 INT4 或 INT8 时，y 的 shape 必须与 x 一致；当 x 为 INT32 时，y 的非尾轴维度必须与 x 一致，且尾轴大小必须为 x 的 8 倍。",
      "source": "x",
      "target": [
        "y"
      ]
    },
    {
      "type": "type_dependency",
      "params": [
        "dstType",
        "y"
      ],
      "expr": "((dstType == 1) and (y.dtype == 'FLOAT16')) or ((dstType == 27) and (y.dtype == 'BFLOAT16'))",
      "description": "dstType 的取值决定 y 的数据类型：1 对应 FLOAT16，27 对应 BFLOAT16。",
      "source": "dstType",
      "target": [
        "y"
      ]
    }
  ],
  "platform_specifics": [
    {
      "platform": "Atlas A3 训练系列产品/Atlas A3 推理系列产品",

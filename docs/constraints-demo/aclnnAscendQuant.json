  "operation_name": "aclnnAscendQuant",
  "description": "对输入x进行量化操作，且scale和offset的size需要是x的最后一维或1。sqrtMode为false时，计算公式为: y = round((x * scale) + offset)。sqrtMode为true时，计算公式为: y = round((x * scale * scale) + offset)。",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "shape_broadcast",
      "params": [
        "x",
        "scale"
      ],
      "expr": "(len(scale.shape) == 1 and scale.shape[0] in [x.shape[-1], 1]) or (len(scale.shape) == len(x.shape) and scale.shape[-1] == x.shape[-1] and all(dim == 1 for dim in scale.shape[:-1]))",
      "description": "scale 的 shape 需要以 x 为基准满足广播约束：要么是一维且长度为 x 最后一维或 1，要么与 x 同维且除最后一维外其余维度为 1、最后一维与 x 相同。",
      "source": "x",
      "target": [
        "scale"
      ]
    },
    {
      "type": "shape_equality",
      "params": [
        "scale",
        "offset"
      ],
      "expr": "(offset is None) or (offset.shape == scale.shape)",
      "description": "offset 为可选参数；当提供 offset 时，其 shape 必须与 scale 相同。",
      "source": "scale",
      "target": [
        "offset"
      ]
    },
    {
      "type": "type_dependency",
      "params": [
        "x",
        "scale"
      ],
      "expr": "(x.dtype == 'FLOAT32') or (scale.dtype == x.dtype)",
      "description": "当 x 的数据类型不是 FLOAT32 时，scale 的数据类型必须与 x 一致。",
      "source": "x",
      "target": [
        "scale"
      ]
    },
    {
      "type": "type_equality",
      "params": [
        "scale",
        "offset"
      ],
      "expr": "(offset is None) or (offset.dtype == scale.dtype)",
      "description": "offset 为可选参数；当提供 offset 时，其数据类型必须与 scale 相同。",
      "source": "scale",
      "target": [
        "offset"
      ]
    },
    {
      "type": "type_dependency",
      "params": [
        "dstType",
        "y"
      ],
      "expr": "((dstType == 2) and (y.dtype == 'INT8')) or ((dstType == 3) and (y.dtype == 'INT32')) or ((dstType == 29) and (y.dtype == 'INT4'))",
      "description": "y 的数据类型由 dstType 决定：2 对应 INT8，3 对应 INT32，29 对应 INT4。",
      "source": "dstType",
      "target": [
        "y"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "dstType",
        "x"
      ],
      "expr": "((dstType == 3) and (x.shape[-1] % 8 == 0)) or ((dstType == 29) and (x.shape[-1] % 2 == 0)) or (dstType == 2)",
      "description": "x 的最后一维大小依赖于 dstType：当 dstType 为 3 时需能被 8 整除，当 dstType 为 29 时需能被 2 整除。",
      "source": "dstType",
      "target": [
        "x"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "x",
        "y"
      ],
      "expr": "((y.dtype == 'INT32') and (len(y.shape) == len(x.shape)) and all(y.shape[i] == x.shape[i] for i in range(len(x.shape) - 1)) and (y.shape[-1] * 8 == x.shape[-1])) or ((y.dtype in ['INT8', 'INT4']) and (y.shape == x.shape))",
      "description": "y 的 shape 由 x 和 y 的数据类型决定：当 y 为 INT32 时，其非尾轴与 x 相同且尾轴为 x 尾轴的 1/8；当 y 为 INT8 或 INT4 时，y 的 shape 与 x 相同。",
      "source": "x",
      "target": [
        "y"
      ]
    }
  ],

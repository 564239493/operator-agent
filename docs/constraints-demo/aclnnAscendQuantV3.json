  "operation_name": "aclnnAscendQuantV3",
  "description": "接口功能：对输入x进行量化操作，支持设置axis以指定scale和offset对应的轴，scale和offset的shape需要满足和axis指定x的轴相等或1。axis当前支持设置最后两个维度。计算公式：sqrtMode为false时，y = round((x * scale) + offset)；sqrtMode为true时，y = round((x * scale * scale) + offset)。",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "shape_dependency",
      "params": [
        "x",
        "scale",
        "axis"
      ],
      "expr": "((len(scale.shape) == 1) and (scale.shape[0] in (x.shape[axis], 1))) or ((len(scale.shape) == len(x.shape)) and (scale.shape[axis] in (x.shape[axis], 1)) and all(scale.shape[i] == 1 for i in range(len(x.shape)) if i != axis))",
      "description": "scale 的 shape 依赖 x 的 shape 和 axis：当 scale 为 1 维时，其第 0 维必须等于 x 的第 axis 维或 1；当 scale 为多维张量时，其维数必须与 x 一致，且第 axis 维等于 x 的第 axis 维或 1，其余维度为 1。",
      "source": "x",
      "target": [
        "scale"
      ]
    },
    {
      "type": "type_equality",
      "params": [
        "x",
        "scale"
      ],
      "expr": "scale.dtype == x.dtype",
      "description": "scale 的数据类型必须与 x 一致。",
      "source": "x",
      "target": [
        "scale"
      ]
    },
    {
      "type": "format_equality",
      "params": [
        "x",
        "scale"
      ],
      "expr": "scale.format == x.format",
      "description": "scale 的数据格式必须与 x 一致。",
      "source": "x",
      "target": [
        "scale"
      ]
    },
    {
      "type": "type_equality",
      "params": [
        "scale",
        "offset"
      ],
      "expr": "offset.dtype == scale.dtype",
      "description": "offset 的数据类型必须与 scale 一致。",
      "source": "scale",
      "target": [
        "offset"
      ]
    },
    {
      "type": "shape_equality",
      "params": [
        "scale",
        "offset"
      ],
      "expr": "offset.shape == scale.shape",
      "description": "offset 的 shape 必须与 scale 一致。",
      "source": "scale",
      "target": [
        "offset"
      ]
    },
    {
      "type": "presence_dependency",
      "params": [
        "x",
        "offset"
      ],
      "expr": "x.format != 'NZ' or offset.is_empty",
      "description": "当 x 的数据格式为 NZ 时，offset 必须为空 Tensor。",
      "source": "x",
      "target": [
        "offset"
      ]
    },
    {
      "type": "value_dependency",
      "params": [
        "x",
        "scale"
      ],
      "expr": "x.format != 'NZ' or all(v == 1 for v in scale.values)",
      "description": "当 x 的数据格式为 NZ 时，scale 的所有元素值都必须为 1。",
      "source": "x",
      "target": [
        "scale"
      ]
    },
    {
      "type": "value_dependency",
      "params": [
        "x",
        "roundMode"
      ],
      "expr": "x.format != 'NZ' or roundMode == 'round'",
      "description": "当 x 的数据格式为 NZ 时，roundMode 只能取 'round'。",
      "source": "x",
      "target": [
        "roundMode"
      ]
    },
    {
      "type": "value_dependency",
      "params": [
        "x",
        "dstType"
      ],
      "expr": "x.format != 'NZ' or dstType == 3",
      "description": "当 x 的数据格式为 NZ 时，dstType 只能取 3（INT32）。",
      "source": "x",
      "target": [
        "dstType"
      ]
    },
    {
      "type": "value_dependency",
      "params": [
        "x",
        "axis"
      ],
      "expr": "axis in (-1, len(x.shape) - 1) or (len(x.shape) >= 2 and axis in (-2, len(x.shape) - 2))",
      "description": "axis 只能指定 x 的最后一个维度，或在 x 维数不少于 2 时指定倒数第二个维度。",
      "source": "x",
      "target": [
        "axis"
      ]
    },
    {
      "type": "value_dependency",
      "params": [
        "x",
        "axis"
      ],
      "expr": "x.format != 'NZ' or axis == -1",
      "description": "当 x 的数据格式为 NZ 时，axis 必须为 -1。",
      "source": "x",
      "target": [
        "axis"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "x",
        "dstType"
      ],
      "expr": "(dstType != 3 or x.shape[-1] % 8 == 0) and (dstType != 29 or x.shape[-1] % 2 == 0)",
      "description": "x 的尾轴大小依赖 dstType：当 dstType 为 3（INT32）时，x 的最后一维必须能被 8 整除；当 dstType 为 29（INT4）时，x 的最后一维必须能被 2 整除。",
      "source": "dstType",
      "target": [
        "x"
      ]
    },
    {
      "type": "type_dependency",
      "params": [
        "dstType",
        "y"
      ],
      "expr": "((dstType == 2) and (y.dtype == 'INT8')) or ((dstType == 3) and (y.dtype == 'INT32')) or ((dstType == 29) and (y.dtype == 'INT4')) or ((dstType == 34) and (y.dtype == 'HIFLOAT8')) or ((dstType == 35) and (y.dtype == 'FLOAT8_E5M2')) or ((dstType == 36) and (y.dtype == 'FLOAT8_E4M3FN'))",
      "description": "y 的数据类型由 dstType 决定。",
      "source": "dstType",
      "target": [
        "y"
      ]
    },
    {
      "type": "shape_dependency",
      "params": [
        "x",
        "dstType",
        "y"
      ],
      "expr": "((dstType == 3) and (len(y.shape) == len(x.shape)) and (y.shape[-1] * 8 == x.shape[-1]) and all(y.shape[i] == x.shape[i] for i in range(len(x.shape) - 1))) or ((dstType != 3) and (y.shape == x.shape))",
      "description": "y 的 shape 依赖 x 和 dstType：当 dstType 为 3（INT32）时，y 的尾轴大小必须为 x 尾轴大小的 1/8，其他维度与 x 一致；其他类型时，y 的 shape 必须与 x 一致。",
      "source": "dstType",
      "target": [
        "y"
      ]
    }
  ],
  "platform_specifics": [
    {

      "constraint_detail": ""
    },
    {
      "platform": "<term>Atlas A2 训练系列产品/Atlas A2 推理系列产品</term>、<term>Atlas A3 训练系列产品/Atlas A3 推理系列产品</term>",
      "description": "参数`x`、`scale`、`offset`的数据格式为NZ时，数据类型仅支持FLOAT32。",
      "constraint_detail": "(x.format != \"NZ\" or x.dtype == \"FLOAT32\") and (scale.format != \"NZ\" or scale.dtype == \"FLOAT32\") and (offset.format != \"NZ\" or offset.dtype == \"FLOAT32\")"
    },
    {
      "platform": "<term>Atlas A2 训练系列产品/Atlas A2 推理系列产品</term>、<term>Atlas A3 训练系列产品/Atlas A3 推理系列产品</term>",
      "description": "出参`y`的数据类型仅支持INT8，INT32，INT4。当数据格式为NZ时，数据类型支持INT32。",
      "constraint_detail": "y.dtype in (\"INT8\", \"INT32\", \"INT4\") and (y.format != \"NZ\" or y.dtype == \"INT32\")"
    },
    {
      "platform": "<term>Atlas A2 训练系列产品/Atlas A2 推理系列产品</term>、<term>Atlas A3 训练系列产品/Atlas A3 推理系列产品</term>",
      "description": "入参`roundMode`：支持取值round，ceil，trunc，floor。当输入`x`的数据格式为NZ时，支持取值round。",
      "constraint_detail": "roundMode in (\"round\", \"ceil\", \"trunc\", \"floor\") and (x.format != \"NZ\" or roundMode == \"round\")"
    },
    {
      "platform": "<term>Atlas A2 训练系列产品/Atlas A2 推理系列产品</term>、<term>Atlas A3 训练系列产品/Atlas A3 推理系列产品</term>",
      "description": "入参`dstType`支持取值2，3，29，分别表示INT8、INT32、INT4。当输入`x`的数据格式为NZ时，支持取值3，表示INT32。",
      "constraint_detail": "dstType in (2, 3, 29) and (x.format != \"NZ\" or dstType == 3)"
    },
    {
      "platform": "<term>Atlas A2 训练系列产品/Atlas A2 推理系列产品</term>、<term>Atlas A3 训练系列产品/Atlas A3 推理系列产品</term>",
      "description": "入参`axis`支持指定x的最后两个维度（假设输入x维度是xDimNum，axis取值范围是[-2，-1]或[xDimNum-2，xDimNum-1]）。",
      "constraint_detail": "axis in (-2, -1, len(x.shape) - 2, len(x.shape) - 1)"
    },
    {

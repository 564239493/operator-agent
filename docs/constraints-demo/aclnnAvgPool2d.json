  "operation_name": "aclnnAvgPool2d",
  "description": "算子功能：对输入Tensor进行窗口为$kH * kW$、步长为$sH * sW$的二维平均池化操作，其中$k$为kernelSize，表示池化窗口的大小，$s$为stride，表示池化操作的步长。\n计算公式：输入input（$N,C,H,W$）、输出out（$N,C,H_{out},W_{out}$）和池化步长（$strides$）、池化窗口大小($kH,kW$)的关系是\nH_{out}=\\lfloor \\frac{H_{in}+2*paddings[0]-kH}{strides[0]}+1 \\rfloor\nW_{out}=\\lfloor \\frac{W_{in}+2*paddings[1]-kW}{strides[1]}+1 \\rfloor\nout(N_i,C_i,h,w)=\\frac{1}{kH*kW}\\sum_{m=0}^{kH-1}\\sum_{n=0}^{kW-1}input(N_i,C_i,strides[0]*h+m,strides[1]*w+n)",
  "api_flow": "two-step",
  "inter_parameter_constraints": [
    {
      "type": "type_equality",
      "params": [
        "self",
        "out"
      ],
      "expr": "self.dtype == out.dtype",
      "description": "out的数据类型需要与self一致。",
      "source": null,
      "target": null
    },
    {
      "type": "format_equality",
      "params": [
        "self",
        "out"
      ],
      "expr": "self.format == out.format",
      "description": "out的数据格式需要与self一致。",
      "source": null,
      "target": null
    },
    {
      "type": "shape_dependency",
      "params": [
        "self",
        "kernelSize",
        "strides",
        "paddings",
        "ceilMode",
        "out"
      ],
      "expr": "len(self.shape) == 4 and len(out.shape) == 4 and out.shape[0] == self.shape[0] and out.shape[1] == self.shape[1] and (((not ceilMode) and out.shape[2] == ((self.shape[2] + 2 * paddings[0] - kernelSize[0]) // strides[0] + 1) and out.shape[3] == ((self.shape[3] + 2 * paddings[len(paddings) - 1] - kernelSize[len(kernelSize) - 1]) // strides[len(strides) - 1] + 1)) or (ceilMode and out.shape[2] == ((self.shape[2] + 2 * paddings[0] - kernelSize[0] + strides[0] - 1) // strides[0] + 1) and out.shape[3] == ((self.shape[3] + 2 * paddings[len(paddings) - 1] - kernelSize[len(kernelSize) - 1] + strides[len(strides) - 1] - 1) // strides[len(strides) - 1] + 1)))",
      "description": "out的shape由self、kernelSize、strides、paddings和ceilMode共同决定，其中N、C维与self一致，H/W维按平均池化公式推导。",
      "source": null,
      "target": null
    },
    {
      "type": "value_dependency",
      "params": [
        "kernelSize",
        "paddings"
      ],
      "expr": "2 * paddings[0] <= kernelSize[0] and 2 * paddings[len(paddings) - 1] <= kernelSize[len(kernelSize) - 1]",
      "description": "paddings各位置的值不能超过kernelSize对应位置的一半；当任一参数长度为1时，该单个值同时作用于H和W方向。",
      "source": "kernelSize",
      "target": [
        "paddings"
      ]
    }
  ],
